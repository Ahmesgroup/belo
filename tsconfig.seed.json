{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": ".ts-seed-out",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["prisma/seed.ts"],
  "exclude": ["node_modules"]
}
