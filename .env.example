# ============================================================
# BELO — Variables d'environnement
# Instructions Windows :
#   1. copy .env.example .env.local   (dans CMD)
#   2. Ouvrir .env.local dans VS Code ou Notepad++
#   3. Remplir les valeurs
# ============================================================

# ── DB Neon (obligatoire) ────────────────────────────────────
# Créer un compte sur https://neon.tech (gratuit)
# Copier l'URL depuis Dashboard → Connection Details
DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/belo?sslmode=require&pgbouncer=true&connect_timeout=15
DIRECT_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/belo?sslmode=require

# ── Auth (obligatoire) ───────────────────────────────────────
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=remplacer-par-64-caracteres-hex
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ── App (obligatoire) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Cron (obligatoire pour Vercel, optionnel en dev) ─────────
CRON_SECRET=dev-secret-123

# ── WhatsApp Meta (optionnel en dev) ─────────────────────────
# En dev sans WhatsApp configuré, les OTP s'affichent dans la console Node
# Créer sur https://developers.facebook.com/
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=

# ── Paiements (optionnel en dev) ─────────────────────────────
# Wave (Sénégal)
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=

# Orange Money (Sénégal)
ORANGE_API_KEY=
ORANGE_MERCHANT_ID=

# Stripe (Europe / diaspora)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Stockage R2 (optionnel) ──────────────────────────────────
# Cloudflare R2 = 10 GB gratuit
# https://dash.cloudflare.com → R2 → Create bucket "belo-media"
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=belo-media
NEXT_PUBLIC_CDN_URL=https://cdn.belo.sn

# ── Email (optionnel) ────────────────────────────────────────
# Resend = 3000 emails/mois gratuit — https://resend.com
RESEND_API_KEY=
EMAIL_FROM=noreply@belo.sn
